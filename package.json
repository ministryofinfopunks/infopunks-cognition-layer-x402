{
  "name": "infopunks-cognition-layer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone x402-paid Cognition Layer for the Infopunks x402 Tool Stack.",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/tools/**/tests.ts tests/**/*.test.ts",
    "readiness": "tsx scripts/readiness.ts",
    "smoke:unpaid": "tsx scripts/smoke-unpaid.ts",
    "smoke:paid-mock": "tsx scripts/smoke-paid-mock.ts"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "dependencies": {
    "@coinbase/x402": "^2.1.0",
    "@x402/extensions": "^2.11.0",
    "fastify": "^5.3.3",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.21",
    "dotenv": "^17.4.2",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
